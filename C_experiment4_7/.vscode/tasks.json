{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build C project",
            "type": "shell",
            "command": "gcc",
            "args": [
                "C_experiment4_7/main.c",
                "C_experiment4_7/add_card.c",
                "C_experiment4_7/cancel_card.c",
                "C_experiment4_7/charge.c",
                "C_experiment4_7/off_computer.c",
                "C_experiment4_7/on_computer.c",
                "C_experiment4_7/refund.c",
                "C_experiment4_7/search_card.c",
                "C_experiment4_7/showMenu.c",
                "C_experiment4_7/statistics.c",
                "C_experiment4_7/storage.c",
                "-o",
                "C_experiment4_7/main.exe",
                "-g",
                "-Wall",
                "-std=c11"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
